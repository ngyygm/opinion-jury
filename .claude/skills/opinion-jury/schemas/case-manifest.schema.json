{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "case-manifest.schema.json",
  "type": "object",
  "required": [
    "case_id",
    "topic",
    "created_at",
    "status",
    "requested_intensity",
    "resolved_intensity",
    "role_pool_status"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "requested_intensity": {
      "type": "string"
    },
    "resolved_intensity": {
      "type": "string"
    },
    "role_pool_status": {
      "enum": [
        "DRAFT",
        "COMMITTED"
      ]
    }
  },
  "additionalProperties": true
}
